{
  "name": "landing-grid-zola-theme",
  "version": "1.0.0",
  "description": "Professional landing grid theme for Zola with Tailwind CSS",
  "keywords": [
    "zola",
    "theme",
    "landing-page",
    "grid",
    "dashboard",
    "tailwind",
    "responsive"
  ],
  "homepage": "https://github.com/fastup-one/landing-grid-zola",
  "repository": {
    "type": "git",
    "url": "https://github.com/fastup-one/landing-grid-zola"
  },
  "license": "MIT",
  "scripts": {
    "build-css": "tailwindcss -i ./src/input.css -o ./themes/landing-grid/static/css/tailwind.css --watch",
    "build-css-prod": "tailwindcss -i ./src/input.css -o ./themes/landing-grid/static/css/tailwind.css --minify",
    "dev": "concurrently \"npm run build-css\" \"zola serve --port 1111\"",
    "build": "npm run build-css-prod && zola build",
    "clean": "rm -rf public themes/landing-grid/static/css/tailwind.css"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.49.0",
    "concurrently": "^9.1.0",
    "html-validate": "^9.7.0",
    "pa11y-ci": "^3.1.0",
    "smol-toml": "^1.3.0"
  }
}
