# Docker build context. The image builds the site from source (npm ci + Tailwind
# + zola build), so exclude only what the build does not need. Do NOT exclude
# content/, data/, src/, or config.toml — the build renders from them.

# VCS & CI
.git
.github

# Dependencies & build output (regenerated inside the image)
node_modules
public
themes/landing-grid/static/css/tailwind.css

# Local gate tooling & browser-test artifacts
.tools
.htmlcheck
.config.htmlcheck.toml
test-results
playwright-report
.lighthouseci

# Dev environment & editor cruft
.devbox
*.log

# Large repo assets not needed to build/serve
screenshot.png
